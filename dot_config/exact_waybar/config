{
  "layer": "overlay",
  "position": "top",
  "margin": "0 0 0 0",
  "spacing": 8,
  "modules-left": [
    "hyprland/workspaces",
    "custom/sep",
    "hyprland/window"
  ],
  "modules-right": [
    "custom/recorder",
    "custom/bus_times",
    "custom/sep",
  //    "network",
  //    "custom/sep",
    "battery",
    "custom/sep",
  //    "temperature",
  //    "custom/sep",
  //    "cpu",
  //    "custom/sep",
    "memory",
    "custom/sep",
    "disk",
    "custom/sep",
    "pulseaudio",
    "custom/sep",
    "clock",
    "custom/sep",
    "tray",
    "custom/sep"
  ],
  "custom/sep": {
    "format": " "
  },
  "custom/recorder": {
    "exec": "~/Scripts/wf-recorder/record-status.sh",
    "interval": 1, 
    "tooltip": true
  },
  "custom/powermenu": {
    "on-click": "~/.config/wofi/scripts/wofipowermenu.py",
    "format": "яАС",
    "tooltip": false
  },
  "network": {
    "interface": "wlan0",
    "interval": 2,
    "format": "{ifname}",
    "format-wifi": "яБв{bandwidthUpBytes} яБг{bandwidthDownBytes}",
    "format-ethernet": "{ipaddr}/{cidr} ґ░КЧ",
    "format-disconnected": "", //An empty format will hide the module.
    "tooltip-format": "{ifname} via {gwaddr} ґ░КЧ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) яЗл",
    "tooltip-format-ethernet": "{ifname} яГБ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 70
  },
  "custom/bluetooth_devices": {
    "exec": "$HOME/.config/waybar/custom_modules/bluetooth_devices.sh",
    "return-type": "json",
    "format": "{}",
    "justify": "center",
    "interval": 5,
    "on-click": "blueman-manager"
  },
  "custom/bus_times": {
    "exec": "$HOME/Scripts/BusTimes/BusTimes 46258",
    "exec-if": "[[ $(iwgetid -r) == 'XS4BYOD' ]]",
    "format": "яИЗ  {}",
    "justify": "center",
    "interval": 30,
  },
  "cpu": {
    "interval": 10,
    "format": "яЛЫ  {max_frequency}%",
  },
  "battery": {
    "bat": "BAT0",
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
    "format-charging": "яГз  {capacity}",
  },
  "memory": {
      "interval": 30,
      "format": "яГЙ  {used:0.1f}"
  },
  "upower": {
    "format": "яГз {}",
    "show-icon": false,
    "native-path": "BAT0",
  },
  "hyprland/workspaces": {
  "format": "  <sup>{icon} </sup>{windows}",
  "format-window-separator": " ",
  "window-rewrite-default": "яДС ",
  "show-special": true,
  "on-scroll-up": "hyprctl dispatch workspace e+1",
  "on-scroll-down": "hyprctl dispatch workspace e-1",
  "window-rewrite": {
      "title<.*youtube.*>": "яЕк ", 
      "title<.*Microsoft Teams.*>": "юЦХ ", 
      "class<firefox>": "яЙй ", 
      "class<zen>": "яЙй ", 
      "class<UpNote>": "яЦн ", 
      "class<com.stremio.stremio>": "яАИ ", 
      "title<.*github.*>": "яДУ ", 
      "title<weechat>": "яЙ║ ", 
      "class<.*jetbrains.*>": "яДб ", 
      "title<.*ChatGPT.*>": "юЛК ", 
      "title<.*Claude.*>": "юЛК ", 
      "kitty": "яДа ", 
    },
  },
  "hyprland/window": {
	"format": "{}",
  "icon": true,
  "icon-size": 18,
	"rewrite": {
      "(.*) - Mozilla Firefox": "ЁЯМО $1",
      "(.*) - zsh": "> [$1]"
    }
  },
  "clock": {
    "tooltip": true,
    "format": "{:%a %e %b, %R}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "first-day"     : 1,
      "mode"          : "year",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "format": {
        "months":     "<span color='#cdd6f4'><b>{}</b></span>",
        "days":       "<span color='#b4befe'><b>{}</b></span>",
        "weeks":      "<span color='#89b4fa'><b> {}</b></span>",
        "weekdays":   "<span color='#f9e2af'><b>{}</b></span>",
        "today":      "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions":  {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "tray": {
    "icon-size": 16,
    "spacing": 2,
    "show-passive-items": "true"
  },
  "disk": {
    "interval": 30,
    "format": "яЗА  {specific_used:0.0f}",
    "unit": "GB"
      // 0.25 GB out of 2000.00 GB available. Alternatively 241.3MiB out of 1.9TiB available.
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "critical-threshold": 80,
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": [
      "яЛЛ",
      "яЛЙ",
      "яЛЗ"
    ]
  },
  "pulseaudio": {
    "format": "{icon}  {volume}",
    "format-bluetooth": "яАе  {volume}",
    "format-muted": "MUTE",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАз",
        "яАи"
      ]
    },
    "scroll-step": 3,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
  }
}
